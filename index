<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Corretor de Redação UFG</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=Spline+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --vinho: #5c0627;
    --magenta: #9c0f48;
    --rosa: #c01f5e;
    --rosa-claro: #e8537a;
    --rosa-bg: #fdf0f4;
    --rosa-medio: #f5cedd;
    --rosa-borda: #e8b3c7;
    --texto: #3a0718;
    --texto-suave: #7a3050;
    --branco: #fff9fb;
    --erro: #c01f5e;
    --sucesso: #6a2e4a;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Spline Sans', sans-serif;
    background: var(--rosa-bg);
    color: var(--texto);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 0%, rgba(156,15,72,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 90% 100%, rgba(192,31,94,0.07) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px 80px;
    position: relative;
    z-index: 1;
  }

  /* HEADER */
  header {
    padding: 52px 0 40px;
    border-bottom: 1px solid var(--rosa-borda);
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .header-eyebrow {
    font-family: 'Spline Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rosa);
  }

  header h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--vinho);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  header h1 em {
    font-style: italic;
    color: var(--magenta);
  }

  .header-sub {
    font-size: 14px;
    color: var(--texto-suave);
    margin-top: 8px;
    line-height: 1.6;
    max-width: 560px;
  }

  /* FORM SECTIONS */
  .form-section {
    margin-bottom: 36px;
  }

  .form-label {
    display: block;
    font-family: 'Fraunces', serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--magenta);
    margin-bottom: 10px;
  }

  .form-label span {
    font-family: 'Spline Sans', sans-serif;
    font-weight: 300;
    font-size: 11px;
    text-transform: none;
    letter-spacing: 0;
    color: var(--texto-suave);
    margin-left: 6px;
  }

  textarea {
    width: 100%;
    border: 1.5px solid var(--rosa-borda);
    border-radius: 10px;
    background: var(--branco);
    color: var(--texto);
    font-family: 'Spline Sans', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    padding: 16px 18px;
    resize: vertical;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  textarea:focus {
    border-color: var(--magenta);
    box-shadow: 0 0 0 3px rgba(156,15,72,0.1);
  }

  textarea::placeholder { color: var(--rosa-borda); }

  /* TOGGLE BUTTONS */
  .toggle-group {
    display: flex;
    gap: 0;
    border: 1.5px solid var(--rosa-borda);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 20px;
    width: fit-content;
  }

  .toggle-btn {
    padding: 10px 22px;
    font-family: 'Spline Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    background: var(--branco);
    color: var(--texto-suave);
    transition: background 0.18s, color 0.18s;
  }

  .toggle-btn.active {
    background: var(--magenta);
    color: #fff;
  }

  .toggle-btn:first-child { border-right: 1px solid var(--rosa-borda); }

  /* UPLOAD AREA */
  .upload-area {
    border: 2px dashed var(--rosa-borda);
    border-radius: 12px;
    background: var(--branco);
    padding: 36px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
  }

  .upload-area:hover, .upload-area.drag-over {
    border-color: var(--magenta);
    background: rgba(156,15,72,0.03);
  }

  .upload-area input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-icon {
    font-size: 32px;
    margin-bottom: 10px;
  }

  .upload-text {
    font-size: 14px;
    color: var(--texto-suave);
    line-height: 1.5;
  }

  .upload-text strong {
    color: var(--magenta);
    font-weight: 600;
  }

  /* THUMBNAILS */
  .thumbnails {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
  }

  .thumb-item {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid var(--rosa-borda);
    background: var(--rosa-bg);
  }

  .thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-remove {
    position: absolute;
    top: 3px;
    right: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--magenta);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* CHECKBOX */
  .checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(156,15,72,0.05);
    border-radius: 10px;
    border: 1px solid var(--rosa-borda);
    cursor: pointer;
    user-select: none;
  }

  .checkbox-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--magenta);
    margin-top: 2px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .checkbox-text {
    font-size: 14px;
    color: var(--texto);
    line-height: 1.5;
  }

  .checkbox-text strong { color: var(--magenta); }

  /* BUTTON */
  .btn-corrigir {
    display: block;
    width: 100%;
    padding: 18px;
    background: var(--magenta);
    color: #fff;
    font-family: 'Fraunces', serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    margin-top: 32px;
    box-shadow: 0 4px 20px rgba(156,15,72,0.25);
  }

  .btn-corrigir:hover:not(:disabled) {
    background: var(--vinho);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(156,15,72,0.35);
  }

  .btn-corrigir:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* LOADING */
  #loading {
    display: none;
    text-align: center;
    padding: 64px 0;
  }

  .loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--rosa-medio);
    border-top-color: var(--magenta);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    margin: 0 auto 20px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-msg {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    color: var(--texto-suave);
    font-style: italic;
    transition: opacity 0.4s;
  }

  /* ERROR */
  #error-box {
    display: none;
    background: rgba(192,31,94,0.08);
    border: 1.5px solid var(--rosa);
    border-radius: 12px;
    padding: 20px 24px;
    margin-top: 24px;
    color: var(--vinho);
    font-size: 14px;
    line-height: 1.6;
  }

  /* RESULT */
  #resultado {
    display: none;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

  /* NOTA BANNER */
  .nota-banner {
    background: linear-gradient(135deg, var(--vinho) 0%, var(--magenta) 100%);
    border-radius: 16px;
    padding: 36px 40px;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 40px;
    margin-bottom: 32px;
    box-shadow: 0 8px 40px rgba(92,6,39,0.3);
  }

  .nota-num {
    font-family: 'Fraunces', serif;
    font-size: 64px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nota-num small {
    font-size: 28px;
    font-weight: 300;
    opacity: 0.7;
  }

  .nota-info h2 {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .nota-info p {
    font-size: 14px;
    opacity: 0.85;
    line-height: 1.5;
  }

  .nota-fonte {
    font-size: 11px;
    opacity: 0.6;
    margin-top: 6px;
    font-style: italic;
  }

  /* CARDS */
  .card {
    background: var(--branco);
    border: 1px solid var(--rosa-borda);
    border-radius: 14px;
    padding: 28px 32px;
    margin-bottom: 24px;
  }

  .card-title {
    font-family: 'Fraunces', serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--magenta);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .card-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rosa-medio);
  }

  /* CRITÉRIO */
  .criterio {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rosa-medio);
  }

  .criterio:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .criterio-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .criterio-nome {
    font-weight: 500;
    font-size: 15px;
    color: var(--texto);
  }

  .criterio-nota {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--magenta);
  }

  .progress-bar {
    height: 6px;
    background: var(--rosa-medio);
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--magenta), var(--rosa-claro));
    border-radius: 99px;
    transition: width 0.8s cubic-bezier(.4,0,.2,1);
  }

  .criterio-comentario {
    font-size: 13.5px;
    color: var(--texto-suave);
    line-height: 1.6;
  }

  /* PONTOS DE ATENÇÃO */
  .ponto-atencao {
    background: rgba(192,31,94,0.06);
    border-left: 3px solid var(--rosa);
    border-radius: 0 8px 8px 0;
    padding: 14px 18px;
    margin-bottom: 12px;
  }

  .ponto-titulo {
    font-weight: 600;
    font-size: 14px;
    color: var(--erro);
    margin-bottom: 4px;
  }

  .ponto-detalhe {
    font-size: 13.5px;
    color: var(--texto-suave);
    line-height: 1.6;
  }

  /* COMPARATIVO */
  .comparativo-texto {
    font-size: 14.5px;
    color: var(--texto);
    line-height: 1.8;
    white-space: pre-line;
  }

  /* TRANSCRICAO / TEXTO MARCADO */
  .texto-redacao {
    font-size: 15px;
    line-height: 1.9;
    color: var(--texto);
    white-space: pre-wrap;
    font-family: 'Spline Sans', sans-serif;
  }

  .texto-redacao mark {
    background: rgba(192,31,94,0.18);
    color: var(--vinho);
    border-bottom: 1.5px solid var(--rosa);
    border-radius: 2px;
    padding: 0 1px;
  }

  /* BTN NOVA */
  .btn-nova {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 12px 24px;
    background: transparent;
    border: 1.5px solid var(--magenta);
    color: var(--magenta);
    border-radius: 8px;
    font-family: 'Spline Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }

  .btn-nova:hover {
    background: var(--magenta);
    color: #fff;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--rosa-borda);
    padding: 28px 0 0;
    margin-top: 60px;
    font-size: 12px;
    color: var(--texto-suave);
    line-height: 1.7;
    opacity: 0.75;
  }

  footer strong { color: var(--magenta); }

  @media (max-width: 600px) {
    .nota-banner { flex-direction: column; gap: 16px; align-items: flex-start; padding: 28px 24px; }
    .nota-num { font-size: 48px; }
    .card { padding: 22px 20px; }
    header h1 { font-size: 2rem; }
  }
  /* LOGO */
  .logo-header {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--rosa-borda);
    margin-bottom: 48px;
  }
  .logo-img {
    width: 120px;
    height: auto;
    flex-shrink: 0;
    border-radius: 12px;
  }
  .logo-text .header-eyebrow {
    margin-bottom: 6px;
  }
  .logo-text h1 {
    margin: 0;
  }
  .logo-text .header-sub {
    margin-top: 8px;
  }
  header { padding: 0; border-bottom: none; margin-bottom: 0; }
</style>
</head>
<body>

<div class="container">

  <header>
    <div class="logo-header">
      <img class="logo-img" src="data:image/jpeg;base64," alt="Prof.ª Fernanda Lara – Professora de Gramática e Redação">
      <div class="logo-text">
        <div class="header-eyebrow">Ferramenta Pedagógica</div>
        <h1>Corretor de<br><em>Redação UFG</em></h1>
        <p class="header-sub">Avaliação orientativa com base nos critérios da banca CS-UFG / Instituto Verbena. A nota é comparada ao modelo geral de dissertação argumentativa.</p>
      </div>
    </div>
  </header>

  <!-- FORMULÁRIO -->
  <div id="form-area">

    <!-- TEMA -->
    <div class="form-section">
      <label class="form-label" for="tema">Tema proposto <span>Cole o enunciado ou tema do vestibular</span></label>
      <textarea id="tema" rows="3" placeholder="Ex: A crise hídrica no Brasil e seus impactos sociais..."></textarea>
    </div>

    <!-- REDAÇÃO -->
    <div class="form-section">
      <label class="form-label">Redação <span>Escolha o modo de envio</span></label>

      <div class="toggle-group">
        <button class="toggle-btn active" id="btn-upload" onclick="setMode('upload')">📷 Foto / Scan</button>
        <button class="toggle-btn" id="btn-texto" onclick="setMode('texto')">✏️ Texto digitado</button>
      </div>

      <!-- UPLOAD -->
      <div id="panel-upload">
        <div class="upload-area" id="upload-area">
          <input type="file" id="file-input" accept="image/*" multiple onchange="handleFiles(this.files)">
          <div class="upload-icon">🖼️</div>
          <div class="upload-text">
            <strong>Arraste as imagens aqui</strong> ou clique para selecionar<br>
            Aceita múltiplas fotos do manuscrito (JPG, PNG, WEBP)
          </div>
        </div>
        <div class="thumbnails" id="thumbnails"></div>
      </div>

      <!-- TEXTO -->
      <div id="panel-texto" style="display:none;">
        <textarea id="redacao-texto" rows="12" placeholder="Cole ou digite o texto da redação aqui..."></textarea>
      </div>
    </div>

    <!-- CHECKBOX -->
    <div class="form-section">
      <label class="checkbox-row">
        <input type="checkbox" id="buscar-edital" checked>
        <span class="checkbox-text">
          🔍 <strong>Buscar na internet o edital e critérios mais recentes da UFG</strong> — recomendado para garantir que a avaliação use os pesos atuais da banca
        </span>
      </label>
    </div>

    <button class="btn-corrigir" onclick="corrigir()">Corrigir Redação →</button>
  </div>

  <!-- LOADING -->
  <div id="loading">
    <div class="loading-spinner"></div>
    <div class="loading-msg" id="loading-msg">Preparando análise...</div>
  </div>

  <!-- ERRO -->
  <div id="error-box"></div>

  <!-- RESULTADO -->
  <div id="resultado"></div>

</div><!-- /container -->

<div class="container">
  <footer>
    ⚠️ <strong>Aviso importante:</strong> A nota exibida é <strong>orientativa e pedagógica</strong>, gerada por inteligência artificial com base nos critérios públicos da banca CS-UFG / Instituto Verbena. Ela <strong>não substitui</strong> a correção oficial da banca examinadora. Pequenas variações nos pesos por edital podem afetar o resultado. Consulte sempre o edital oficial e a correção da banca.
  </footer>
</div>

<script>
  // ─── CONFIG ────────────────────────────────────────────────
  const API_URL = "https://SEU-WORKER.workers.dev";

  // ─── STATE ─────────────────────────────────────────────────
  let modo = 'upload';
  let imagens = []; // [{file, dataUrl, base64, mediaType}]

  // ─── MODO TOGGLE ───────────────────────────────────────────
  function setMode(m) {
    modo = m;
    document.getElementById('btn-upload').classList.toggle('active', m === 'upload');
    document.getElementById('btn-texto').classList.toggle('active', m === 'texto');
    document.getElementById('panel-upload').style.display = m === 'upload' ? '' : 'none';
    document.getElementById('panel-texto').style.display = m === 'texto' ? '' : 'none';
  }

  // ─── UPLOAD ────────────────────────────────────────────────
  const uploadArea = document.getElementById('upload-area');
  uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
  uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
  uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
  });

  function handleFiles(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = e => {
        const dataUrl = e.target.result;
        const base64 = dataUrl.split(',')[1];
        const id = Date.now() + Math.random();
        imagens.push({ id, file, dataUrl, base64, mediaType: file.type });
        renderThumbs();
      };
      reader.readAsDataURL(file);
    });
  }

  function removeImg(id) {
    imagens = imagens.filter(i => i.id !== id);
    renderThumbs();
  }

  function renderThumbs() {
    const el = document.getElementById('thumbnails');
    el.innerHTML = imagens.map(img => `
      <div class="thumb-item">
        <img src="${img.dataUrl}" alt="Página da redação">
        <button class="thumb-remove" onclick="removeImg(${img.id})" title="Remover">×</button>
      </div>
    `).join('');
  }

  // ─── LOADING MESSAGES ──────────────────────────────────────
  const loadMsgs = [
    "Buscando o edital mais recente...",
    "Lendo e transcrevendo o manuscrito...",
    "Analisando coerência e coesão...",
    "Verificando norma culta...",
    "Calculando a nota por critérios UFG...",
    "Preparando o relatório..."
  ];
  let loadInterval;

  function startLoading() {
    let i = 0;
    const el = document.getElementById('loading-msg');
    el.textContent = loadMsgs[0];
    loadInterval = setInterval(() => {
      i = (i + 1) % loadMsgs.length;
      el.style.opacity = 0;
      setTimeout(() => { el.textContent = loadMsgs[i]; el.style.opacity = 1; }, 300);
    }, 2600);
  }

  function stopLoading() { clearInterval(loadInterval); }

  // ─── CORRIGIR ──────────────────────────────────────────────
  async function corrigir() {
    const tema = document.getElementById('tema').value.trim();
    const buscarEdital = document.getElementById('buscar-edital').checked;

    // Validação
    if (!tema) { alert('Por favor, informe o tema da redação.'); return; }

    if (modo === 'upload' && imagens.length === 0) {
      alert('Adicione ao menos uma foto da redação.'); return;
    }
    if (modo === 'texto' && !document.getElementById('redacao-texto').value.trim()) {
      alert('Cole o texto da redação.'); return;
    }

    // UI
    document.getElementById('form-area').style.display = 'none';
    document.getElementById('loading').style.display = 'block';
    document.getElementById('error-box').style.display = 'none';
    document.getElementById('resultado').style.display = 'none';
    startLoading();

    try {
      const systemPrompt = `Você é um corretor especialista em redações de vestibular da UFG (Universidade Federal de Goiás / CS-UFG / Instituto Verbena). Sua função é avaliar a redação sob DOIS olhares simultâneos e comparar:

1. CRIVO OFICIAL DA UFG: Use os critérios e pesos do edital mais recente que encontrar (ou que já conhece). Os critérios variam por edital — adapte-se aos atuais. Gênero dissertativo-argumentativo. Nota máxima: 24 pontos. Abaixo de 10 é desclassificatório.

2. MODELO GERAL DE DISSERTAÇÃO ARGUMENTATIVA: Avalie também pela estrutura clássica (introdução/tese, desenvolvimento/argumentação, conclusão/proposta). Compare os dois olhares.

Se receber imagens (manuscrito), transcreva fielmente o texto ANTES de avaliar, preservando todos os erros originais.

Identifique pontos de atenção críticos: fuga ao tema, ausência de tese clara, problemas graves de coesão, desvios da norma culta, cópia dos textos motivadores.

RESPONDA APENAS com um objeto JSON válido, sem markdown, sem cercas \`\`\`, sem texto antes ou depois. O JSON deve seguir EXATAMENTE este schema:
{
  "transcricao": "texto transcrito fielmente (se manuscrito) ou repetição do texto recebido",
  "nota_total": <número>,
  "nota_max": 24,
  "veredito": "frase curta de avaliação geral",
  "criterios": [
    {"nome": "nome do critério", "nota": <número>, "max": <número>, "comentario": "comentário detalhado"}
  ],
  "comparativo": "análise comparativa entre crivo UFG vs modelo geral dissertativo-argumentativo",
  "pontos_atencao": [
    {"titulo": "título do problema", "detalhe": "explicação detalhada"}
  ],
  "texto_marcado": "o texto da redação com trechos problemáticos entre <<erro>>trecho problemático<</erro>>",
  "edital_fonte": "referência ao edital/fonte consultada ou 'Base de conhecimento geral UFG'"
}`;

      // Montar content do usuário
      const userContent = [];

      if (modo === 'upload') {
        imagens.forEach((img, idx) => {
          userContent.push({
            type: 'image',
            source: { type: 'base64', media_type: img.mediaType, data: img.base64 }
          });
        });
        userContent.push({
          type: 'text',
          text: `TEMA DO VESTIBULAR: ${tema}\n\nAs imagens acima são fotos do manuscrito da redação. Por favor: (1) transcreva fielmente o texto, (2) avalie pelos critérios da UFG e pelo modelo geral, (3) responda apenas com o JSON conforme instruções.`
        });
      } else {
        const textoRed = document.getElementById('redacao-texto').value.trim();
        userContent.push({
          type: 'text',
          text: `TEMA DO VESTIBULAR: ${tema}\n\nTEXTO DA REDAÇÃO:\n${textoRed}\n\nAvalie pelos critérios da UFG e pelo modelo geral de dissertação argumentativa. Responda apenas com o JSON conforme instruções.`
        });
      }

      const body = {
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: 'user', content: userContent }]
      };

      if (buscarEdital) {
        body.tools = [{ type: 'web_search_20250305', name: 'web_search' }];
      }

      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      if (!res.ok) {
        const err = await res.text();
        throw new Error(`Erro da API (${res.status}): ${err}`);
      }

      const data = await res.json();

      // Extrair texto de todos os blocos (text, tool_result, etc.)
      const rawText = (data.content || [])
        .map(b => b.type === 'text' ? b.text : '')
        .filter(Boolean)
        .join('\n');

      // Parse seguro do JSON
      const json = parseJSON(rawText);
      stopLoading();
      document.getElementById('loading').style.display = 'none';
      renderResultado(json);

    } catch (err) {
      stopLoading();
      document.getElementById('loading').style.display = 'none';
      document.getElementById('form-area').style.display = 'block';
      const box = document.getElementById('error-box');
      box.style.display = 'block';
      box.innerHTML = `<strong>Não foi possível concluir a correção.</strong><br>${err.message}<br><br><small>Verifique a URL do worker, sua conexão e tente novamente.</small>`;
    }
  }

  // ─── PARSE JSON SEGURO ─────────────────────────────────────
  function parseJSON(raw) {
    // Remove markdown fences
    let text = raw.replace(/```json|```/gi, '').trim();
    // Localiza o primeiro { e último }
    const start = text.indexOf('{');
    const end = text.lastIndexOf('}');
    if (start === -1 || end === -1) throw new Error('A IA não retornou um JSON válido. Resposta: ' + raw.slice(0, 200));
    text = text.slice(start, end + 1);
    return JSON.parse(text);
  }

  // ─── RENDER RESULTADO ──────────────────────────────────────
  function renderResultado(d) {
    const pct = Math.round((d.nota_total / d.nota_max) * 100);

    // Texto marcado: converter <<erro>>...<</erro>> em <mark>
    const textoMarcado = (d.texto_marcado || d.transcricao || '')
      .replace(/<<erro>>([\s\S]*?)<\/erro>>/g, '<mark>$1</mark>');

    // Critérios
    const criteriosHtml = (d.criterios || []).map(c => {
      const p = Math.round((c.nota / c.max) * 100);
      return `
        <div class="criterio">
          <div class="criterio-header">
            <span class="criterio-nome">${esc(c.nome)}</span>
            <span class="criterio-nota">${c.nota}<small>/${c.max}</small></span>
          </div>
          <div class="progress-bar"><div class="progress-fill" style="width:${p}%"></div></div>
          <div class="criterio-comentario">${esc(c.comentario)}</div>
        </div>`;
    }).join('');

    // Pontos de atenção
    const pontosHtml = (d.pontos_atencao || []).length === 0
      ? '<p style="color:var(--texto-suave);font-size:14px;">Nenhum ponto crítico identificado.</p>'
      : (d.pontos_atencao || []).map(p => `
        <div class="ponto-atencao">
          <div class="ponto-titulo">⚠ ${esc(p.titulo)}</div>
          <div class="ponto-detalhe">${esc(p.detalhe)}</div>
        </div>`).join('');

    const html = `
      <div class="nota-banner">
        <div class="nota-num">${d.nota_total}<small>/${d.nota_max}</small></div>
        <div class="nota-info">
          <h2>${esc(d.veredito)}</h2>
          <p>${pct}% da pontuação máxima · ${nota_desc(d.nota_total, d.nota_max)}</p>
          <p class="nota-fonte">Fonte: ${esc(d.edital_fonte || 'Base de conhecimento UFG')}</p>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Critérios de avaliação</div>
        ${criteriosHtml}
      </div>

      <div class="card">
        <div class="card-title">Crivo UFG × Modelo geral</div>
        <div class="comparativo-texto">${esc(d.comparativo || '')}</div>
      </div>

      <div class="card">
        <div class="card-title">Pontos de atenção</div>
        ${pontosHtml}
      </div>

      <div class="card">
        <div class="card-title">Texto da redação analisado</div>
        <div class="texto-redacao">${textoMarcado}</div>
      </div>

      <button class="btn-nova" onclick="novaCorracao()">← Corrigir outra redação</button>
    `;

    const el = document.getElementById('resultado');
    el.innerHTML = html;
    el.style.display = 'block';
  }

  function nota_desc(nota, max) {
    const p = nota / max;
    if (p < 10/24) return '⚠ Abaixo do mínimo — desclassificatório';
    if (p < 0.6) return 'Abaixo da média';
    if (p < 0.75) return 'Dentro da média';
    if (p < 0.9) return 'Acima da média';
    return 'Excelente desempenho';
  }

  function esc(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ─── NOVA CORREÇÃO ─────────────────────────────────────────
  function novaCorracao() {
    document.getElementById('resultado').style.display = 'none';
    document.getElementById('form-area').style.display = 'block';
    document.getElementById('tema').value = '';
    document.getElementById('redacao-texto').value = '';
    imagens = [];
    renderThumbs();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>
